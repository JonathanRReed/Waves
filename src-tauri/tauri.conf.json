{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Waves",
  "version": "0.1.0",
  "identifier": "com.jonathanreed.waves",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Waves",
        "width": 1180,
        "height": 860,
        "minWidth": 980,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "A cleaner cross-platform per-app audio mixer.",
    "longDescription": "Waves is a sleek cross-platform desktop utility for per-app audio control, quick tray access, and a compact top bar workflow.",
    "category": "Music"
  }
}
